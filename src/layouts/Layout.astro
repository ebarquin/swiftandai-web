---
interface Props {
    title: string;
    description?: string;
    image?: string;
    date?: string;
    author?: string;
    schema?: object;
}

const { title, description, image, date, author, schema } = Astro.props;
const siteUrl = 'https://swiftandai.com';
const pageUrl = `${siteUrl}${Astro.url.pathname}`;
const ogImage = image ? `${siteUrl}${image}` : `${siteUrl}/web-app-manifest-512x512.png`;
const metaDescription = description ?? 'AI Systems Engineering — agentes LLM, RAG y arquitecturas conversacionales. Swift e iOS como ventaja diferencial.';
const isArticle = !!date;
const pageTitle = !title ? 'Swift & AI' : title.includes('Swift & AI') ? title : `${title} | Swift & AI`;
---

<!doctype html>
<html lang="es" class="dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="color-scheme" content="dark" />

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
        <link rel="shortcut icon" href="/favicon.ico" />
        <link rel="manifest" href="/site.webmanifest" />
        <link rel="alternate" type="application/rss+xml" title="Swift & AI" href="/rss.xml" />

        <title>{pageTitle}</title>
        <meta name="description" content={metaDescription} />
        <link rel="canonical" href={pageUrl} />

        <meta property="og:type" content={isArticle ? 'article' : 'website'} />
        <meta property="og:url" content={pageUrl} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={metaDescription} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:locale" content="es_ES" />
        <meta property="og:site_name" content="Swift & AI" />
        {isArticle && <meta property="article:published_time" content={date} />}
        {isArticle && author && <meta property="article:author" content={author} />}
        <meta name="author" content={author ?? 'Eugenio Barquín'} />

        {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={pageUrl} />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={metaDescription} />
        <meta name="twitter:image" content={ogImage} />

        {!import.meta.env.DEV && (
          <script
            defer
            src="https://umami-production-9af2.up.railway.app/script.js"
            data-website-id="55b4425f-b455-49ef-b89f-7696d646ab0e">
          </script>
        )}

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />

        <style is:global>
:root {
  --bg-0: #08090c; --bg-1: #0d0f15; --bg-2: #12141c; --bg-3: #181b25;
  --line: rgba(255,255,255,0.08); --line-2: rgba(255,255,255,0.14);
  --fg: #eceef4; --fg-dim: #a3a9b8; --fg-mute: #5e6575;
  --swift: oklch(0.76 0.16 52); --swift-soft: oklch(0.76 0.16 52 / 0.14);
  --ai: oklch(0.80 0.13 205);   --ai-soft: oklch(0.80 0.13 205 / 0.14);
  --accent: var(--swift);
  --maxw: 1180px; --r: 16px;
  --font-display: "Open Sans", system-ui, sans-serif;
  --font-mono: "JetBrains Mono", ui-monospace, monospace;
}
*, *::before, *::after { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin: 0; background: var(--bg-0); color: var(--fg);
  font-family: var(--font-display); font-size: 17px; line-height: 1.6;
  -webkit-font-smoothing: antialiased; letter-spacing: -0.01em; overflow-x: hidden;
}
body::before {
  content: ""; position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background:
    radial-gradient(900px 600px at 12% -5%, oklch(0.76 0.16 52 / 0.08), transparent 60%),
    radial-gradient(1000px 700px at 95% 8%, oklch(0.80 0.13 205 / 0.08), transparent 60%);
}
a { color: inherit; text-decoration: none; }
h1,h2,h3,h4 { margin: 0; letter-spacing: -0.03em; line-height: 1.1; }
::selection { background: oklch(0.80 0.13 205 / 0.35); }

/* NAV */
.layout-nav {
  position: sticky; top: 0; z-index: 50;
  backdrop-filter: blur(14px);
  background: color-mix(in oklab, var(--bg-0) 72%, transparent);
  border-bottom: 1px solid var(--line);
}
.layout-nav-in {
  max-width: var(--maxw); margin: 0 auto; padding: 16px 28px;
  display: flex; align-items: center; justify-content: space-between;
}
.layout-brand { display: flex; align-items: center; gap: 12px; font-weight: 700; }
.layout-brand-mark {
  width: 34px; height: 34px; border-radius: 9px; display: grid; place-items: center;
  background: linear-gradient(135deg, var(--swift), var(--ai));
  color: #08090c; font-family: var(--font-mono); font-weight: 700; font-size: 11px; letter-spacing: -0.02em;
  flex: none;
}
.layout-brand b { font-size: 17px; letter-spacing: -0.02em; }
.layout-brand span { color: var(--fg-mute); font-weight: 400; }
.layout-nav-links { display: flex; align-items: center; gap: 28px; font-size: 15px; }
.layout-nav-links a { color: var(--fg-dim); transition: color .18s; }
.layout-nav-links a:hover { color: var(--fg); }
.layout-nav-links .icon { display: grid; place-items: center; width: 20px; height: 20px; }
.layout-nav-links svg { width: 18px; height: 18px; }

/* PROGRESS BAR */
#progress-bar {
  position: absolute; bottom: 0; left: 0; height: 2px;
  background: linear-gradient(90deg, var(--swift), var(--ai));
  width: 0; transition: width 150ms linear;
}

/* MAIN */
.layout-main {
  max-width: 1060px;
  margin: 0 auto;
  padding: 0 28px;
  position: relative;
  z-index: 1;
}
@media (max-width: 680px) {
  .layout-main { padding: 0 20px; }
}

/* FOOTER */
.layout-footer {
  border-top: 1px solid var(--line); padding: 40px 0 60px;
  margin-top: 40px; position: relative; z-index: 1;
}
.layout-foot-in {
  max-width: var(--maxw); margin: 0 auto; padding: 0 28px;
  display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap;
}
.layout-foot-in .mono { color: var(--fg-mute); font-family: var(--font-mono); font-size: 13px; }
.layout-foot-links { display: flex; gap: 22px; font-family: var(--font-mono); font-size: 13px; }
.layout-foot-links a { color: var(--fg-dim); transition: color .18s; }
.layout-foot-links a:hover { color: var(--accent); }

@media (max-width: 680px) {
  .layout-nav-in { padding: 14px 20px; }
  .layout-nav-links { gap: 18px; }
  .layout-foot-in { padding: 0 20px; }
}
@media (prefers-reduced-motion: reduce) {
  html { scroll-behavior: auto; }
}
        </style>
    </head>
    <body>
        <nav class="layout-nav">
            <div id="progress-bar"></div>
            <div class="layout-nav-in">
                <a class="layout-brand" href="/">
                    <span class="layout-brand-mark">S&amp;AI</span>
                    <b>Swift &amp; AI <span>// blog</span></b>
                </a>
                <div class="layout-nav-links">
                    <a href="/">Blog</a>
                    <a href="/about">Sobre mí</a>
                    <a class="icon" href="https://github.com/ebarquin" target="_blank" rel="noopener" aria-label="GitHub">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 016 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"/></svg>
                    </a>
                    <a class="icon" href="https://www.linkedin.com/in/eugenio-barquin/" target="_blank" rel="noopener" aria-label="LinkedIn">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33 0-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 110-4.14 2.07 2.07 0 010 4.14zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.8 0 0 .77 0 1.73v20.54C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>
                    </a>
                </div>
            </div>
        </nav>

        <main class="layout-main">
            <slot />
        </main>

        <footer class="layout-footer">
            <div class="layout-foot-in">
                <span class="mono">© {new Date().getFullYear()} // SWIFT &amp; AI — Building with Swift. Thinking about AI.</span>
                <div class="layout-foot-links">
                    <a href="/rss.xml">RSS</a>
                    <a href="https://github.com/ebarquin" target="_blank" rel="noopener">GitHub</a>
                    <a href="https://www.linkedin.com/in/eugenio-barquin/" target="_blank" rel="noopener">LinkedIn</a>
                    <a href="/about">Sobre mí</a>
                </div>
            </div>
        </footer>

        <script>
            window.addEventListener('scroll', () => {
                const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
                const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
                const bar = document.getElementById('progress-bar');
                if (bar) bar.style.width = (height > 0 ? (winScroll / height) * 100 : 0) + '%';
            });
        </script>
    </body>
</html>
