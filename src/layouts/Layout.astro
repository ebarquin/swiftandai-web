---
import ThemeIcon from '../components/ThemeIcon.astro';

interface Props {
    title: string;
    description?: string;
    image?: string;
    date?: string;
    author?: string;
    schema?: object;
}

const { title, description, image, date, author, schema } = Astro.props;
const siteUrl = 'https://swiftandai.com';
const pageUrl = `${siteUrl}${Astro.url.pathname}`;
const ogImage = image ? `${siteUrl}${image}` : `${siteUrl}/web-app-manifest-512x512.png`;
const metaDescription = description ?? 'Explorando la intersección del desarrollo nativo en Apple y la inteligencia artificial integrada.';
const isArticle = !!date;
const pageTitle = !title ? 'Swift & AI' : title.includes('Swift & AI') ? title : `${title} | Swift & AI`;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="color-scheme" content="light dark" />
        
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
        <link rel="shortcut icon" href="/favicon.ico" />
        <link rel="manifest" href="/site.webmanifest" />
        <link rel="alternate" type="application/rss+xml" title="Swift & AI" href="/rss.xml" />
        
        <title>{pageTitle}</title>
        <meta name="description" content={metaDescription} />
        <link rel="canonical" href={pageUrl} />

        <meta property="og:type" content={isArticle ? 'article' : 'website'} />
        <meta property="og:url" content={pageUrl} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={metaDescription} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:locale" content="es_ES" />
        <meta property="og:site_name" content="Swift & AI" />
        {isArticle && <meta property="article:published_time" content={date} />}
        {isArticle && author && <meta property="article:author" content={author} />}
        <meta name="author" content={author ?? 'Eugenio Barquín'} />

        {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={pageUrl} />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={metaDescription} />
        <meta name="twitter:image" content={ogImage} />
        {!import.meta.env.DEV && (
          <script
            defer
            src="https://umami-production-9af2.up.railway.app/script.js"
            data-website-id="55b4425f-b455-49ef-b89f-7696d646ab0e">
          </script>
        )}
        
        <script is:inline>
            const theme = (() => {
              if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                return localStorage.getItem('theme');
              }
              if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                return 'dark';
              }
              return 'light';
            })();
          
            if (theme === 'dark') {
              document.documentElement.classList.add('dark');
            } else {
              document.documentElement.classList.remove('dark');
            }
            window.localStorage.setItem('theme', theme);
        </script>

        <style is:global>
            html.dark {
                color-scheme: dark;
            }
            @media (prefers-reduced-motion: reduce) {
                .animate-pulse {
                    animation: none;
                }
            }
        </style>
    </head>
    <body class="font-sans bg-[#fbfbfd] dark:bg-[#1d1d1f] text-[#1d1d1f] dark:text-[#f5f5f7] antialiased transition-colors duration-300">
        <nav class="sticky top-0 z-50 w-full bg-white/80 dark:bg-[#1d1d1f]/80 backdrop-blur-xl border-b border-gray-200/50 dark:border-gray-800/50 transition-all duration-300">
            <div id="progress-bar" class="absolute bottom-0 left-0 h-[2px] bg-primary w-0 transition-all duration-150"></div>
            
            <div class="max-w-4xl mx-auto px-6 h-24 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="relative group">
                        <img
                            src="/autor.png"
                            alt="Eugenio Barquín"
                            width="1024"
                            height="1536"
                            class="w-12 h-12 rounded-full border border-gray-200 dark:border-gray-700 shadow-sm transition-transform group-hover:scale-105 object-cover"
                        />
                        <div class="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 rounded-full bg-primary border-2 border-white dark:border-[#1d1d1f] animate-pulse"></div>
                    </div>
                    <a href="/" class="font-bold tracking-tighter text-xl hover:opacity-70 transition-opacity no-underline !text-gray-900 dark:!text-white">
                        Swift & AI
                    </a>
                </div>

                <div class="flex items-center gap-6 text-[12px] font-bold uppercase tracking-[0.2em]">
                    <a href="/" class="text-gray-900 dark:text-gray-100 hover:text-primary transition-colors no-underline">Blog</a>
                    <a href="/about" class="text-gray-400 dark:text-gray-500 hover:text-primary transition-colors no-underline">Sobre mí</a>
                    <ThemeIcon />
                    <a href="https://www.linkedin.com/in/eugenio-barquin/" target="_blank" aria-label="LinkedIn" class="p-2.5 bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 rounded-full hover:bg-primary dark:hover:bg-primary transition-all duration-300 shadow-sm">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    </a>
                    <a href="https://github.com/ebarquin" target="_blank" aria-label="GitHub" class="p-2.5 bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 rounded-full hover:bg-primary dark:hover:bg-primary transition-all duration-300 shadow-sm">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                    </a>
                </div>
            </div>
        </nav>

        <main class="max-w-4xl mx-auto px-6 py-20">
            <slot />
        </main>

        <footer class="max-w-4xl mx-auto px-6 py-16 border-t border-gray-100 dark:border-gray-800 text-[11px] text-gray-400 dark:text-gray-500 font-mono tracking-[0.3em] uppercase">
            <div class="flex justify-between items-center">
                <span>&copy; {new Date().getFullYear()} // SWIFT & AI</span>
                <div class="flex items-center gap-6">
                    <a href="/rss.xml" class="text-gray-400 dark:text-gray-500 hover:text-primary transition-colors no-underline flex items-center gap-1.5">
                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
                        RSS
                    </a>
                    <span class="text-gray-500 dark:text-gray-400 italic">Building with Swift. Thinking about AI.</span>
                </div>
            </div>
        </footer>

        <script>
            window.onscroll = function() {
                const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
                const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
                const scrolled = (winScroll / height) * 100;
                const progressBar = document.getElementById("progress-bar");
                if (progressBar) progressBar.style.width = scrolled + "%";
            };
        </script>
    </body>
</html>