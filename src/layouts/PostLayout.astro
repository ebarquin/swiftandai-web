---
import Layout from "./Layout.astro";

const { title, frontmatter } = Astro.props;
const { image, imageAlt, description, date } = frontmatter ?? {};
const author = 'Eugenio Barquín';
const siteUrl = 'https://swiftandai.com';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: image ? `${siteUrl}${image}` : undefined,
  datePublished: date,
  author: {
    '@type': 'Person',
    name: author,
    url: `${siteUrl}/about`,
  },
  publisher: {
    '@type': 'Person',
    name: author,
    url: siteUrl,
  },
  url: `${siteUrl}${Astro.url.pathname}`,
};
---

<Layout title={title} description={description} image={image} date={date} author={author} schema={schema}>
  <article class="prose prose-slate dark:prose-invert prose-headings:text-gray-900 dark:prose-headings:text-white prose-a:text-primary leading-relaxed max-w-none">
    <header class="mb-24 not-prose max-w-4xl">
      {date && (
        <time datetime={date} class="block text-sm font-mono text-gray-400 mb-6 tracking-wide">
          {new Date(date).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      )}
      <h1 class="text-6xl md:text-7xl font-extrabold tracking-tight leading-[1.05] text-gray-900 dark:text-white">
        {title}
      </h1>

      {description && (
        <p class="mt-6 text-2xl md:text-3xl font-semibold tracking-tight text-gray-700 dark:text-gray-300">
          {description}
        </p>
      )}
    </header>

    {image && (
  <div class="mb-20 not-prose flex justify-center">
    <img
      src={image}
      alt={imageAlt || title}
      width="1536"
      height="1024"
      class="w-full max-w-3xl rounded-[2rem] border border-gray-100 dark:border-gray-800 shadow-sm object-cover"
    />
  </div>
)}
    <slot />
  </article>

  <!-- Autor (epílogo del post) -->
  <section class="mt-20 pt-10 border-t border-gray-100 dark:border-gray-800 not-prose">
    <div class="flex items-center gap-6 p-8 bg-gray-50/50 dark:bg-gray-800/20 rounded-[2rem] border border-gray-100 dark:border-gray-800">
      <img
        src="/autor.png"
        alt="Eugenio Barquín"
        width="1024"
        height="1536"
        class="w-20 h-20 rounded-full border-4 border-white dark:border-gray-800 shadow-md grayscale hover:grayscale-0 transition-all duration-500 object-cover"
      />
      <div>
        <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400 dark:text-gray-500 mb-1">
          Autor
        </p>
        <h3 class="text-xl font-bold !text-gray-900 dark:!text-white">
          Eugenio
        </h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
          AI Systems Engineer. Agentes LLM, RAG y sistemas conversacionales. Swift & iOS como ventaja diferencial.
        </p>
      </div>
    </div>
  </section>
</Layout>