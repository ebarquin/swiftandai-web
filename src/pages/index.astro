---
// --- IMPORTS ORIGINALES ---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// --- IMPORTS AÑADIDOS PARA EL BLOG ---
import { getCollection } from 'astro:content'; 
import BlogPost from '../components/BlogPost.astro'; 

// Obtiene todos los posts de la colección 'blog'
const posts = await getCollection('blog');

// Ordena los posts por fecha (más reciente primero) y toma los 5 primeros
const sortedPosts = posts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 5); 
---

<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
            <section class="hero-section">
                <div class="hero-content">
                    <h1>Blog sobre Swift y Inteligencia Artificial</h1>
                    <p>
                        Explorando la sinergia entre el desarrollo nativo de Apple (iOS, Swift) 
                        y las arquitecturas de modelos de Machine Learning (CoreML, LLMs). 
                        Publicaciones semanales en español.
                    </p>
                    <a href="/sobre-mi" class="cta-button">Conoce al autor</a>
                </div>
                
                <div class="hero-avatar">
                    <img 
                        src="/avatar.png" 
                        alt="Avatar del Autor" 
                        width="250" 
                        height="250" 
                    />
                </div>
            </section>

            <section class="recent-posts-container">
                <h2>Últimas publicaciones</h2>
                <div class="post-list">
                    {sortedPosts.map((post) => (
                        <BlogPost 
                            url={`/blog/${post.slug}/`} 
                            title={post.data.title} 
                            pubDate={post.data.pubDate} 
                            description={post.data.description} 
                        />
                    ))}
                </div>
            </section>
		</main>
		<Footer />
	</body>
</html>