---
const posts = await Astro.glob('./blog/*.md');
const sorted = posts.sort((a, b) =>
    new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);

const featured = sorted[0];
const gridPosts = sorted.slice(1);

function getDomain(tags: string[]): string {
    const t = tags.map(s => s.toLowerCase());
    const isSwift = t.some(s => ['swift', 'swiftui', 'ios'].includes(s));
    const isAI    = t.some(s => ['ia', 'agentes llm', 'python', 'langgraph', 'rag', 'nlp', 'fastapi'].includes(s));
    const isBoth  = t.includes('core ml') || (isSwift && isAI);
    if (isBoth) return 'both';
    if (isAI)   return 'ai';
    return 'swift';
}

function readingTime(content: string): number {
    return Math.max(1, Math.ceil(content.split(/\s+/).length / 200));
}

function patClass(domain: string, i: number): string {
    const variants: Record<string, string[]> = {
        swift: ['pat swift', 'pat swift layers'],
        ai:    ['pat ai', 'pat ai grid'],
        both:  ['pat dual ai', 'pat dual layers'],
    };
    const arr = variants[domain] ?? variants['swift'];
    return arr[i % arr.length];
}

function tagClass(tag: string): string {
    const t = tag.toLowerCase();
    if (['ia','agentes llm','python','langgraph','rag','nlp','fastapi'].includes(t)) return 'ai';
    if (['swift','swiftui','ios','core ml'].includes(t)) return 'swift';
    return '';
}

function visibleTags(tags: string[]): string[] {
    return tags.slice(0, 3);
}
---

<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Swift & AI — iOS, Core ML y agentes LLM</title>
<meta name="description" content="AI Systems Engineering — agentes LLM, RAG y arquitecturas conversacionales. Swift e iOS como ventaja diferencial." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<style>
:root {
  --bg-0: #08090c; --bg-1: #0d0f15; --bg-2: #12141c; --bg-3: #181b25;
  --line: rgba(255,255,255,0.08); --line-2: rgba(255,255,255,0.14);
  --fg: #eceef4; --fg-dim: #a3a9b8; --fg-mute: #5e6575;
  --swift: oklch(0.76 0.16 52); --swift-soft: oklch(0.76 0.16 52 / 0.14);
  --ai: oklch(0.80 0.13 205);   --ai-soft: oklch(0.80 0.13 205 / 0.14);
  --accent: var(--swift);
  --maxw: 1180px; --r: 16px;
  --font-display: "Open Sans", system-ui, sans-serif;
  --font-mono: "JetBrains Mono", ui-monospace, monospace;
  --depth: 1;
}
* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin: 0; background: var(--bg-0); color: var(--fg);
  font-family: var(--font-display); font-size: 17px; line-height: 1.6;
  -webkit-font-smoothing: antialiased; letter-spacing: -0.01em; overflow-x: hidden;
}
body::before {
  content: ""; position: fixed; inset: 0; z-index: 0; pointer-events: none;
  opacity: calc(var(--depth) * 1);
  background:
    radial-gradient(900px 600px at 12% -5%, oklch(0.76 0.16 52 / 0.10), transparent 60%),
    radial-gradient(1000px 700px at 95% 8%, oklch(0.80 0.13 205 / 0.10), transparent 60%),
    radial-gradient(800px 800px at 50% 120%, oklch(0.72 0.10 280 / 0.08), transparent 60%);
}
.wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 28px; position: relative; z-index: 1; }
a { color: inherit; text-decoration: none; }
h1,h2,h3 { margin: 0; font-weight: 700; letter-spacing: -0.03em; line-height: 1.02; }
::selection { background: oklch(0.80 0.13 205 / 0.35); }
.mono { font-family: var(--font-mono); letter-spacing: 0; }
.kicker {
  font-family: var(--font-mono); font-size: 12.5px; letter-spacing: 0.16em;
  text-transform: uppercase; color: var(--fg-mute);
  display: inline-flex; align-items: center; gap: 10px; white-space: nowrap;
}
.kicker::before { content: ""; width: 22px; height: 1px; background: var(--accent); }

/* NAV */
.nav {
  position: sticky; top: 0; z-index: 50;
  backdrop-filter: blur(14px);
  background: color-mix(in oklab, var(--bg-0) 72%, transparent);
  border-bottom: 1px solid var(--line);
}
.nav-in {
  max-width: var(--maxw); margin: 0 auto; padding: 16px 28px;
  display: flex; align-items: center; justify-content: space-between;
}
.brand { display: flex; align-items: center; gap: 12px; font-weight: 700; }
.brand-mark {
  width: 34px; height: 34px; border-radius: 9px; display: grid; place-items: center;
  background: linear-gradient(135deg, var(--swift), var(--ai));
  color: #08090c; font-family: var(--font-mono); font-weight: 700; font-size: 11px; letter-spacing: -0.02em;
}
.brand b { font-size: 17px; letter-spacing: -0.02em; }
.brand span { color: var(--fg-mute); font-weight: 400; }
.nav-links { display: flex; align-items: center; gap: 28px; font-size: 15px; }
.nav-links a { color: var(--fg-dim); transition: color .18s; }
.nav-links a:hover { color: var(--fg); }
.nav-links .icon { display: grid; place-items: center; width: 20px; height: 20px; }
.nav-links svg { width: 18px; height: 18px; }

/* HERO */
.hero { padding: 96px 0 64px; }
.hero-grid { display: grid; grid-template-columns: 1.55fr 1fr; gap: 56px; align-items: end; }
.hero h1 { font-size: clamp(40px, 6.2vw, 76px); margin: 26px 0 0; text-wrap: balance; }
.hero h1 .hl-swift { color: var(--swift); }
.hero h1 .hl-ai { color: var(--ai); }
.hero-sub { margin: 26px 0 0; color: var(--fg-dim); font-size: 19px; max-width: 52ch; text-wrap: pretty; }
.hero-who { margin-top: 30px; display: flex; align-items: center; gap: 14px; font-size: 15px; color: var(--fg-dim); }
.who-avatar { width: 44px; height: 44px; border-radius: 50%; overflow: hidden; border: 1px solid var(--line-2); flex: none; }
.who-avatar img { width: 100%; height: 100%; object-fit: cover; }
.hero-who b { color: var(--fg); font-weight: 600; }
.badges { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 34px; }
.badge {
  font-family: var(--font-mono); font-size: 13px; padding: 8px 14px; border-radius: 999px;
  border: 1px solid var(--line-2); background: var(--bg-1); color: var(--fg-dim);
  display: inline-flex; align-items: center; gap: 8px;
  transition: transform .18s, border-color .18s, color .18s;
}
.badge .dot { width: 7px; height: 7px; border-radius: 50%; }
.badge:hover { transform: translateY(-2px); color: var(--fg); border-color: var(--accent); }
.hero-art {
  aspect-ratio: 1 / 1.05; border-radius: var(--r); border: 1px solid var(--line);
  background: var(--bg-1); position: relative; overflow: hidden;
}
.hero-art .pat { position: absolute; inset: 0; }
.hero-art-cap {
  position: absolute; left: 18px; bottom: 16px; right: 18px;
  font-family: var(--font-mono); font-size: 12px; color: var(--fg-mute);
  display: flex; justify-content: space-between;
}

/* HERO VARIANT SWITCH */
.hero-vb { display: none; }
[data-hero="b"] .hero-va { display: none; }
[data-hero="b"] .hero-vb { display: block; text-align: center; }
[data-hero="b"] .hero { padding-top: 84px; }

/* HERO VARIANT B — code editor */
.hero-vb .kicker { display: inline-flex; }
.code-win {
  max-width: 880px; margin: 34px auto 0; position: relative;
  border: 1px solid var(--line-2); border-radius: 14px; background: var(--bg-1);
  box-shadow: 0 48px 120px -50px #000,
              0 0 80px -26px oklch(0.76 0.16 52 / .38),
              0 0 80px -26px oklch(0.80 0.13 205 / .38);
  overflow: hidden; text-align: left;
}
.code-win::before {
  content: ""; position: absolute; inset: 0; border-radius: 14px; padding: 1px;
  background: linear-gradient(135deg, var(--swift), transparent 38%, transparent 62%, var(--ai));
  -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
  -webkit-mask-composite: xor; mask-composite: exclude; pointer-events: none; opacity: .85;
}
.code-bar {
  display: flex; align-items: center; gap: 14px; padding: 13px 18px;
  border-bottom: 1px solid var(--line);
  background: color-mix(in oklab, var(--bg-2) 70%, transparent);
}
.code-bar .dots { display: flex; gap: 7px; }
.code-bar .dots i { width: 11px; height: 11px; border-radius: 50%; display: block; }
.code-bar .dots i:nth-child(1){ background: oklch(0.70 0.17 25); }
.code-bar .dots i:nth-child(2){ background: oklch(0.83 0.14 85); }
.code-bar .dots i:nth-child(3){ background: oklch(0.78 0.14 150); }
.code-file { font-family: var(--font-mono); font-size: 13px; color: var(--fg-dim); }
.code-meta { margin-left: auto; font-family: var(--font-mono); font-size: 12px; color: var(--fg-mute); white-space: nowrap; }
.code-body {
  font-family: var(--font-mono); font-size: clamp(13.5px, 1.5vw, 18px);
  line-height: 2; padding: 22px 26px 26px; color: var(--fg-dim);
}
.cl { display: flex; align-items: flex-start; gap: 20px; }
.cl .ln { color: var(--fg-mute); opacity: .5; width: 20px; text-align: right; flex: none; user-select: none; font-size: .82em; line-height: 2.4; }
.cl .cd { flex: 1; min-width: 0; }
.tab { display: inline-block; width: 2.4ch; }
.tok-kw { color: var(--swift); }
.tok-type { color: var(--ai); }
.tok-prop { color: color-mix(in oklab, var(--ai) 65%, var(--fg)); }
.cmt { color: var(--fg-mute); }
.code-body .code-h1 {
  display: inline; font-family: var(--font-mono); font-size: inherit;
  font-weight: 500; line-height: 2; letter-spacing: 0; color: var(--fg); margin: 0; text-wrap: pretty;
}
.cur { display: inline-block; width: 9px; height: 1.02em; background: var(--ai); margin-left: 5px; transform: translateY(3px); animation: blink 1.1s steps(1) infinite; }
@keyframes blink { 50% { opacity: 0; } }
.vb-sub { text-align: center; margin: 32px auto 0; }
.vb-badges { justify-content: center; }
.vb-who { justify-content: center; margin-top: 28px; text-align: left; }

/* SECTIONS */
section.block { padding: 72px 0; position: relative; z-index: 1; }
.sec-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; margin-bottom: 36px; }
.sec-head h2 { font-size: clamp(28px, 3.4vw, 40px); }
.sec-head .lead { color: var(--fg-dim); margin-top: 10px; font-size: 16px; max-width: 46ch; }
.sec-link { font-family: var(--font-mono); font-size: 13px; color: var(--fg-dim); white-space: nowrap; }
.sec-link:hover { color: var(--accent); }

/* ARCHITECTURE DIAGRAM */
.arch-svg { position: absolute; inset: 0; width: 100%; height: 100%; padding: 16px; }
.arch-label { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: .12em; text-transform: uppercase; fill: var(--fg-mute); }
.arch-node { stroke-width: 1.2; fill: var(--bg-2); }
.swift-node { stroke: oklch(0.76 0.16 52 / 0.55); }
.ai-node    { stroke: oklch(0.80 0.13 205 / 0.55); }
.arch-text  { font-family: var(--font-mono); font-size: 11.5px; fill: var(--fg-dim); letter-spacing: -0.01em; }
.arch-edge  { stroke-width: 1.5; stroke-dasharray: 4 3; }
.swift-edge { stroke: oklch(0.76 0.16 52 / 0.45); }
.ai-edge    { stroke: oklch(0.80 0.13 205 / 0.45); }
.arch-arrow { }
.swift-arrow { fill: oklch(0.76 0.16 52 / 0.55); }
.ai-arrow    { fill: oklch(0.80 0.13 205 / 0.55); }
.arch-center-ring { fill: none; stroke: url(#arch-grad); stroke-width: 1; opacity: .5; }
.arch-center { fill: var(--bg-2); stroke: url(#arch-grad); stroke-width: 1.5; }
.arch-center-text { font-family: var(--font-mono); font-size: 11px; font-weight: 700; fill: var(--fg); }
.arch-center-sub  { font-family: var(--font-mono); font-size: 8px; fill: var(--fg-mute); }
.arch-edge-center { stroke: var(--line-2); stroke-width: 1.5; stroke-dasharray: 3 3; }
.arch-badge { fill: var(--bg-2); stroke: var(--line-2); stroke-width: 1; }
.arch-badge-dot { fill: oklch(0.80 0.13 205 / 0.8); }
.arch-badge-text { font-family: var(--font-mono); font-size: 10px; fill: var(--fg-mute); letter-spacing: .06em; }

/* ABSTRACT PATTERNS */
.pat { --c: var(--ai); }
.pat.swift { --c: var(--swift); }
.pat.ai    { --c: var(--ai); }
.pat.dual  { --c: var(--swift); }
.pat.ai::before, .pat.dual::after {
  content: ""; position: absolute; inset: 0;
  background-image: radial-gradient(circle, color-mix(in oklab, var(--ai) 80%, transparent) 1.6px, transparent 2px);
  background-size: 26px 26px;
  mask-image: radial-gradient(120% 100% at 80% 20%, #000 30%, transparent 75%);
  opacity: .55;
}
.pat.swift::before {
  content: ""; position: absolute; inset: -40%;
  background: repeating-radial-gradient(circle at 30% 70%, transparent 0 16px, color-mix(in oklab, var(--swift) 55%, transparent) 16px 17px);
  opacity: .5;
}
.pat::after {
  content: ""; position: absolute; inset: 0;
  background: radial-gradient(70% 60% at 75% 22%, color-mix(in oklab, var(--c) 38%, transparent), transparent 70%);
}
.pat.layers::before {
  content: ""; position: absolute; inset: 0;
  background: repeating-linear-gradient(180deg, transparent 0 22px, color-mix(in oklab, var(--c) 30%, transparent) 22px 23px);
  mask-image: linear-gradient(120deg, #000, transparent 80%); opacity: .6;
}
.pat.grid::before {
  content: ""; position: absolute; inset: 0;
  background:
    linear-gradient(color-mix(in oklab, var(--c) 35%, transparent) 1px, transparent 1px) 0 0 / 30px 30px,
    linear-gradient(90deg, color-mix(in oklab, var(--c) 35%, transparent) 1px, transparent 1px) 0 0 / 30px 30px;
  mask-image: radial-gradient(120% 120% at 20% 10%, #000 20%, transparent 70%); opacity: .5;
}

/* FEATURED */
.featured {
  display: grid; grid-template-columns: 1.15fr 1fr;
  border: 1px solid var(--line); border-radius: var(--r);
  overflow: hidden; background: var(--bg-1); transition: border-color .25s;
}
.featured:hover { border-color: var(--line-2); }
.featured-art { position: relative; min-height: 420px; background: var(--bg-2); overflow: hidden; }
.featured-body { padding: 44px; display: flex; flex-direction: column; }
.tagrow { display: flex; flex-wrap: wrap; gap: 8px; }
.tag { font-family: var(--font-mono); font-size: 12px; padding: 5px 11px; border-radius: 999px; border: 1px solid var(--line-2); color: var(--fg-dim); }
.tag.swift { color: var(--swift); border-color: color-mix(in oklab, var(--swift) 45%, transparent); }
.tag.ai    { color: var(--ai);    border-color: color-mix(in oklab, var(--ai) 45%, transparent); }
.featured-body h3 { font-size: clamp(28px, 3.2vw, 42px); margin: 22px 0 0; text-wrap: balance; }
.featured-body p { color: var(--fg-dim); margin: 18px 0 0; font-size: 17px; max-width: 46ch; }
.featured-meta {
  margin-top: auto; padding-top: 30px; display: flex; align-items: center; gap: 16px;
  font-family: var(--font-mono); font-size: 13px; color: var(--fg-mute);
}
.read-cta { display: inline-flex; align-items: center; gap: 9px; color: var(--accent); font-weight: 600; font-size: 15px; margin-left: auto; }
.read-cta svg { width: 16px; height: 16px; transition: transform .2s; }
.featured:hover .read-cta svg { transform: translateX(4px); }
.fbadge {
  position: absolute; top: 20px; left: 20px; z-index: 2;
  font-family: var(--font-mono); font-size: 11px; letter-spacing: .14em;
  text-transform: uppercase; color: var(--bg-0); font-weight: 700;
  padding: 6px 12px; border-radius: 999px;
  background: linear-gradient(135deg, var(--swift), var(--ai));
}

/* GRID + FILTERS */
.filters { display: flex; gap: 10px; flex-wrap: wrap; }
.filter {
  font-family: var(--font-mono); font-size: 13px; padding: 9px 16px; border-radius: 999px;
  border: 1px solid var(--line-2); background: transparent; color: var(--fg-dim);
  cursor: pointer; transition: all .18s;
}
.filter:hover { color: var(--fg); }
.filter.active { color: var(--bg-0); background: var(--fg); border-color: var(--fg); }
.filter[data-f="swift"].active { background: var(--swift); border-color: var(--swift); }
.filter[data-f="ai"].active    { background: var(--ai);    border-color: var(--ai); }
.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
.card {
  border: 1px solid var(--line); border-radius: var(--r); overflow: hidden;
  background: var(--bg-1); display: flex; flex-direction: column;
  transition: transform .25s cubic-bezier(.2,.7,.3,1), border-color .25s, box-shadow .25s;
}
.card:hover { transform: translateY(-6px); border-color: var(--line-2); box-shadow: 0 24px 50px -28px rgba(0,0,0,0.8); }
.card-art { position: relative; height: 168px; overflow: hidden; background: var(--bg-2); }
.card-body { padding: 22px 22px 24px; display: flex; flex-direction: column; gap: 14px; flex: 1; }
.card h3 { font-size: 20px; text-wrap: balance; }
.card p { color: var(--fg-dim); font-size: 15px; margin: 0; }
.card-meta { margin-top: auto; font-family: var(--font-mono); font-size: 12px; color: var(--fg-mute); display: flex; align-items: center; gap: 10px; }
.card.hide { display: none; }

/* AHORA MISMO */
.now-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
.now-col { border: 1px solid var(--line); border-radius: var(--r); padding: 28px; background: var(--bg-1); transition: border-color .25s, transform .25s; }
.now-col:hover { border-color: var(--line-2); transform: translateY(-4px); }
.now-head { font-family: var(--font-mono); font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--fg-mute); display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
.now-head .pip { width: 9px; height: 9px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 0 4px color-mix(in oklab, var(--accent) 20%, transparent); }
.now-col ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 16px; }
.now-col li { font-size: 15.5px; color: var(--fg); line-height: 1.45; }
.now-col li span { display: block; color: var(--fg-mute); font-family: var(--font-mono); font-size: 12px; margin-top: 4px; }

/* PROYECTOS */
.proj-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
.proj { border: 1px solid var(--line); border-radius: var(--r); padding: 30px; background: var(--bg-1); display: flex; flex-direction: column; gap: 16px; min-height: 240px; transition: border-color .25s, transform .25s; }
.proj:hover { border-color: var(--line-2); transform: translateY(-4px); }
.proj-top { display: flex; align-items: center; justify-content: space-between; }
.proj-glyph { width: 46px; height: 46px; border-radius: 12px; display: grid; place-items: center; font-family: var(--font-mono); font-weight: 700; font-size: 18px; border: 1px solid var(--line-2); }
.proj-glyph.swift { color: var(--swift); background: var(--swift-soft); }
.proj-glyph.ai    { color: var(--ai);    background: var(--ai-soft); }
.proj h3 { font-size: 22px; }
.proj p { color: var(--fg-dim); font-size: 15px; margin: 0; flex: 1; }
.proj-stack { display: flex; flex-wrap: wrap; gap: 7px; }
.proj-stack span { font-family: var(--font-mono); font-size: 11.5px; color: var(--fg-mute); padding: 3px 9px; border: 1px solid var(--line); border-radius: 999px; }
.proj-link { font-family: var(--font-mono); font-size: 13px; color: var(--fg-dim); display: inline-flex; gap: 7px; align-items: center; }
.proj:hover .proj-link { color: var(--accent); }

/* WIP PROJECTS */
.proj-wip { opacity: .6; cursor: default; }
.proj-wip:hover { transform: none; border-color: var(--line); }
.proj-wip-label { font-family: var(--font-mono); font-size: 12px; color: var(--fg-mute); }

/* STACK */
.stack-wrap { border: 1px solid var(--line); border-radius: var(--r); background: var(--bg-1); padding: 40px; }
.stack-group + .stack-group { margin-top: 30px; padding-top: 30px; border-top: 1px solid var(--line); }
.stack-group h4 { font-family: var(--font-mono); font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--fg-mute); margin: 0 0 18px; font-weight: 500; }
.stack-row { display: flex; flex-wrap: wrap; gap: 12px; }
.tech { display: inline-flex; align-items: center; gap: 10px; padding: 11px 18px; border-radius: 12px; border: 1px solid var(--line-2); background: var(--bg-2); font-size: 15px; font-weight: 500; transition: transform .18s, border-color .18s; }
.tech:hover { transform: translateY(-3px); }
.tech .tg { width: 26px; height: 26px; border-radius: 7px; display: grid; place-items: center; font-family: var(--font-mono); font-size: 12px; font-weight: 700; color: var(--bg-0); }
.tech.s .tg { background: var(--swift); }
.tech.s:hover { border-color: var(--swift); }
.tech.a .tg { background: var(--ai); }
.tech.a:hover { border-color: var(--ai); }

/* IMÁGENES EN CARDS */
.featured-img {
  position: absolute; inset: 0; width: 100%; height: 100%;
  object-fit: contain; object-position: center;
  opacity: 0.85; transition: opacity .3s;
}
.featured:hover .featured-img { opacity: 1; }
.card-img {
  position: absolute; inset: 0; width: 100%; height: 100%;
  object-fit: cover; object-position: center top;
  opacity: 0.82; transition: opacity .3s;
}
.card:hover .card-img { opacity: 1; }

/* RSS */
.rss {
  border: 1px solid var(--line); border-radius: var(--r);
  background: radial-gradient(120% 140% at 0% 0%, var(--swift-soft), transparent 55%),
              radial-gradient(120% 140% at 100% 100%, var(--ai-soft), transparent 55%),
              var(--bg-1);
  padding: 56px; display: flex; align-items: center; justify-content: space-between; gap: 40px; flex-wrap: wrap;
}
.rss h2 { font-size: clamp(28px, 3.6vw, 44px); text-wrap: balance; }
.rss p { color: var(--fg-dim); margin: 14px 0 0; max-width: 44ch; }
.rss-actions { display: flex; gap: 14px; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: 10px; padding: 15px 26px; border-radius: 12px; font-weight: 600; font-size: 16px; font-family: var(--font-display); border: 1px solid var(--line-2); transition: transform .18s, border-color .18s; }
.btn svg { width: 18px; height: 18px; }
.btn.primary { background: linear-gradient(135deg, var(--swift), var(--ai)); color: var(--bg-0); border: 0; }
.btn:hover { transform: translateY(-3px); }
.btn.ghost:hover { border-color: var(--fg); color: var(--fg); }

/* FOOTER */
footer { border-top: 1px solid var(--line); padding: 40px 0 60px; margin-top: 40px; position: relative; z-index: 1; }
.foot-in { display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; }
.foot-in .mono { color: var(--fg-mute); font-size: 13px; }
.foot-links { display: flex; gap: 22px; font-family: var(--font-mono); font-size: 13px; }
.foot-links a { color: var(--fg-dim); }
.foot-links a:hover { color: var(--accent); }

/* SCROLL REVEAL */
.reveal { opacity: 0; transform: translateY(24px); transition: opacity .7s cubic-bezier(.2,.7,.3,1), transform .7s cubic-bezier(.2,.7,.3,1); }
.reveal.in { opacity: 1; transform: none; }


/* RESPONSIVE */
@media (max-width: 960px) {
  .hero-grid { grid-template-columns: 1fr; gap: 40px; }
  .hero-art { max-width: 380px; }
  .featured { grid-template-columns: 1fr; }
  .featured-art { min-height: 240px; }
  .grid, .now-grid, .proj-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 680px) {
  .wrap, .nav-in { padding-left: 20px; padding-right: 20px; }
  .nav-links { gap: 18px; }
  .grid, .now-grid, .proj-grid { grid-template-columns: 1fr; }
  .hero { padding-top: 64px; }
  .sec-head { flex-direction: column; align-items: flex-start; }
  .rss { padding: 36px 28px; }
  .featured-body { padding: 30px; }
}
@media (prefers-reduced-motion: reduce) {
  .reveal { transition: none; opacity: 1; transform: none; }
  html { scroll-behavior: auto; }
}
</style>
